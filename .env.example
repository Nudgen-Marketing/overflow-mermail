NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_ENOKI_API_KEY=your-public-enoki-zklogin-api-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
# Leave blank to use the current origin plus /auth, e.g. http://localhost:3000/auth.
NEXT_PUBLIC_ENOKI_REDIRECT_URL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clone_mail

# Public app URL for links and internal callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Email Routing -> Next.js internal ingestion.
INTERNAL_EMAIL_SECRET=replace-with-a-long-random-secret

# OpenAI-compatible LLM configuration.
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Cloudflare Email Sending REST API.
CLOUDFLARE_EMAIL_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=your-cloudflare-email-send-token

# Encrypts workspace Harbor and MemWal delegate secrets stored in Postgres.
WORKSPACE_SECRET_KEY=replace-with-a-long-random-secret

# MemWal / Walrus Memory relayer.
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
